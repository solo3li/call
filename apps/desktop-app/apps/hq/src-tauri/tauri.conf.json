{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "FoodRMS HQ",
  "version": "0.1.0",
  "identifier": "com.foodrms.hq",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "FoodRMS Desktop",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/solo3li/foodRMS/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEzQTJFNzBDMTVDREYzOTUKUldTVjg4MFZET2VpbzJJems1NXQ0WXgwU2JRaWtOY28yY2hJUUgzWS94Q1NNVlFSK2dCZjU5STkK"
    }
  }
}
