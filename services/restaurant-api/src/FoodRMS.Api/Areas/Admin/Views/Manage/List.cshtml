@model List<object>
@{
    ViewData["Title"] = ViewBag.EntityName;
    Type entityType = ViewBag.EntityType;
    var properties = entityType.GetProperties()
        .Where(p => FoodRMS.Api.Areas.Admin.Controllers.ManageController.IsBindableType(p.PropertyType))
        .ToList();
    var hasId = properties.Any(p => p.Name.Equals("Id", StringComparison.OrdinalIgnoreCase));
}

<div class="page-header d-flex justify-content-between align-items-center mb-4 p-4 bg-white rounded-4 shadow-sm">
    <div class="d-flex align-items-center">
        <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-3 me-3">
            <i class="bi bi-table fs-4"></i>
        </div>
        <div>
            <h1 class="page-title h3 mb-1 fw-bolder text-dark">@ViewBag.EntityName Management</h1>
            <p class="text-muted mb-0 small">Manage and control all records for @ViewBag.EntityName.</p>
        </div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-light fw-bold shadow-sm border"><i class="bi bi-arrow-left me-1"></i> Back</a>
        @if(hasId) {
            <a asp-action="Create" asp-route-id="@ViewBag.EntityName" class="btn btn-primary fw-bold shadow-sm"><i class="bi bi-plus-lg me-1"></i> Create New</a>
        }
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        <div class="table-responsive">
            <table id="advancedDataTable" class="table table-hover align-middle w-100" style="border-collapse: separate; border-spacing: 0 8px;">
                <thead class="bg-light">
                    <tr>
                        @foreach(var prop in properties) {
                            <th class="text-nowrap text-uppercase text-secondary fw-bolder" style="font-size: 0.8rem; letter-spacing: 0.5px;">@prop.Name</th>
                        }
                        @if(hasId) {
                            <th class="text-end text-nowrap text-uppercase text-secondary fw-bolder" style="font-size: 0.8rem; letter-spacing: 0.5px;">Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach(var item in Model) {
                        <tr class="bg-white shadow-sm rounded" style="transition: transform 0.2s;">
                            @foreach(var prop in properties) {
                                var val = prop.GetValue(item);
                                if (val == null) {
                                    <td class="text-muted fst-italic small"><span class="badge bg-light text-secondary border">null</span></td>
                                } else if (val is bool b) {
                                    <td>
                                        @if(b) {
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-2 py-1"><i class="bi bi-check-circle-fill me-1"></i> True</span>
                                        } else {
                                            <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-2 py-1"><i class="bi bi-x-circle-fill me-1"></i> False</span>
                                        }
                                    </td>
                                } else {
                                    <td class="text-truncate fw-medium text-dark" style="max-width: 250px;" title="@val.ToString()">
                                        @if(prop.Name.Equals("TenantId", StringComparison.OrdinalIgnoreCase) && val != null && Guid.TryParse(val.ToString(), out Guid parsedTenantId) && parsedTenantId != Guid.Empty) {
                                            <a href="/Admin/Manage/ExploreTenant?tenantId=@parsedTenantId" class="text-decoration-none text-primary fw-bold" title="Manage Tenant Data">
                                                @val.ToString() <i class="bi bi-box-arrow-up-right ms-1 small"></i>
                                            </a>
                                        } else {
                                            @val.ToString()
                                        }
                                    </td>
                                }
                            }
                            @if(hasId) {
                                var idProp = properties.First(p => p.Name.Equals("Id", StringComparison.OrdinalIgnoreCase));
                                var idVal = idProp.GetValue(item)?.ToString();
                                <td class="text-end text-nowrap">
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Details" asp-route-id="@ViewBag.EntityName" asp-route-pk="@idVal" class="btn btn-sm btn-light border-end text-info" title="View Details"><i class="bi bi-eye-fill"></i></a>
                                        <a asp-action="Edit" asp-route-id="@ViewBag.EntityName" asp-route-pk="@idVal" class="btn btn-sm btn-light border-end text-primary" title="Edit Record"><i class="bi bi-pencil-fill"></i></a>
                                        <a asp-action="Delete" asp-route-id="@ViewBag.EntityName" asp-route-pk="@idVal" class="btn btn-sm btn-light text-danger" title="Delete Record"><i class="bi bi-trash-fill"></i></a>
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#advancedDataTable').DataTable({
                responsive: true,
                dom: '<"d-flex justify-content-between align-items-center mb-3"Bf>rt<"d-flex justify-content-between align-items-center mt-3"ip>',
                buttons: [
                    { extend: 'copy', className: 'btn btn-sm btn-light border fw-bold shadow-sm me-1' },
                    { extend: 'csv', className: 'btn btn-sm btn-light border fw-bold shadow-sm me-1' },
                    { extend: 'excel', className: 'btn btn-sm btn-success bg-opacity-10 text-success border border-success border-opacity-25 fw-bold shadow-sm me-1' },
                    { extend: 'pdf', className: 'btn btn-sm btn-danger bg-opacity-10 text-danger border border-danger border-opacity-25 fw-bold shadow-sm me-1' },
                    { extend: 'print', className: 'btn btn-sm btn-light border fw-bold shadow-sm' }
                ],
                language: {
                    search: "",
                    searchPlaceholder: "Search records..."
                },
                pageLength: 25,
                drawCallback: function() {
                    $('.dataTables_filter input').addClass('form-control shadow-sm').css('border-radius', '8px');
                }
            });
            
            // Fix layout of the DataTable controls
            $('.dt-buttons').addClass('d-flex gap-1');
        });
    </script>
}