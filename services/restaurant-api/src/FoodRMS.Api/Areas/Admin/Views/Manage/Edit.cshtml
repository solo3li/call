@model object
@{
    ViewData["Title"] = "Edit " + ViewBag.EntityName;
    Type entityType = ViewBag.EntityType;
    var properties = entityType.GetProperties()
        .Where(p => FoodRMS.Api.Areas.Admin.Controllers.ManageController.IsBindableType(p.PropertyType))
        .ToList();
        
    var idProp = properties.FirstOrDefault(p => p.Name.Equals("Id", StringComparison.OrdinalIgnoreCase));
    var idVal = idProp?.GetValue(Model)?.ToString();
}

<div class="page-header d-flex justify-content-between align-items-center mb-4 p-4 bg-white rounded-4 shadow-sm">
    <div class="d-flex align-items-center">
        <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-3 me-3">
            <i class="bi bi-pencil-square fs-4"></i>
        </div>
        <div>
            <h1 class="page-title h3 mb-1 fw-bolder text-dark">Edit @ViewBag.EntityName</h1>
            <p class="text-muted mb-0 small">Update the record details and save changes.</p>
        </div>
    </div>
    <div>
        <a asp-action="List" asp-route-id="@ViewBag.EntityName" class="btn btn-light fw-bold shadow-sm border"><i class="bi bi-arrow-left me-1"></i> Back to List</a>
    </div>
</div>

<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-white border-bottom p-4">
                <h5 class="fw-bolder mb-0 text-dark">Update Information</h5>
            </div>
            <div class="card-body p-4 p-lg-5">
                <form asp-action="Edit" asp-route-id="@ViewBag.EntityName" asp-route-pk="@idVal" method="post" class="needs-validation" novalidate>
                    
                    @foreach(var prop in properties) {
                        var isId = prop.Name.Equals("Id", StringComparison.OrdinalIgnoreCase);
                        var isRequired = Nullable.GetUnderlyingType(prop.PropertyType) == null && prop.PropertyType != typeof(string) && !isId;
                        var reqAttr = isRequired ? "required" : "";
                        var reqStar = isRequired ? "<span class='text-danger'>*</span>" : "";
                        var val = prop.GetValue(Model);

                        if (isId) {
                            <input type="hidden" name="@prop.Name" value="@val" />
                            <div class="mb-4">
                                <label class="form-label fw-bold text-secondary mb-2" style="font-size: 0.9rem;">Record ID</label>
                                <input type="text" class="form-control form-control-lg bg-light text-muted" value="@val" readonly disabled>
                            </div>
                            continue;
                        }

                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary mb-2" style="font-size: 0.9rem;">
                                @prop.Name @Html.Raw(reqStar)
                            </label>
                            
                            @if (prop.PropertyType == typeof(bool) || prop.PropertyType == typeof(bool?)) {
                                var isChecked = val != null && (bool)val;
                                <div class="form-check form-switch fs-5">
                                    <input class="form-check-input" type="checkbox" role="switch" id="@prop.Name" name="@prop.Name" value="true" @(isChecked ? "checked" : "")>
                                    <label class="form-check-label ms-2 mt-1 fs-6 text-dark" for="@prop.Name">Enable / Active</label>
                                </div>
                            } 
                            else if (prop.PropertyType == typeof(DateTime) || prop.PropertyType == typeof(DateTime?)) {
                                var dateStr = val != null ? ((DateTime)val).ToString("yyyy-MM-ddTHH:mm") : "";
                                <input type="datetime-local" class="form-control form-control-lg bg-light" id="@prop.Name" name="@prop.Name" value="@dateStr" @reqAttr>
                            }
                            else if (prop.PropertyType == typeof(int) || prop.PropertyType == typeof(decimal) || prop.PropertyType == typeof(double)) {
                                <input type="number" step="any" class="form-control form-control-lg bg-light" id="@prop.Name" name="@prop.Name" value="@val" @reqAttr>
                            }
                            else if (prop.PropertyType == typeof(string) && prop.Name.ToLower().Contains("description")) {
                                <textarea class="form-control bg-light" id="@prop.Name" name="@prop.Name" rows="4">@val</textarea>
                            }
                            else {
                                <input type="text" class="form-control form-control-lg bg-light" id="@prop.Name" name="@prop.Name" value="@val" @reqAttr>
                            }
                            
                            @if(isRequired){
                                <div class="invalid-feedback">Please provide a valid @prop.Name.</div>
                            }
                        </div>
                    }

                    <div class="mt-5 pt-3 border-top d-flex justify-content-end gap-2">
                        <a asp-action="List" asp-route-id="@ViewBag.EntityName" class="btn btn-lg btn-light fw-bold border text-muted px-4">Cancel</a>
                        <button type="submit" class="btn btn-lg btn-primary fw-bold px-5 shadow-sm"><i class="bi bi-save-fill me-2"></i> Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms)
                .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault()
                            event.stopPropagation()
                        }
                        form.classList.add('was-validated')
                    }, false)
                })
        })()
    </script>
}