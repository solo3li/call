@model object
@{
    ViewData["Title"] = "Delete " + ViewBag.EntityName;
    Type entityType = ViewBag.EntityType;
    var properties = entityType.GetProperties()
        .Where(p => FoodRMS.Api.Areas.Admin.Controllers.ManageController.IsBindableType(p.PropertyType))
        .ToList();
        
    var idProp = properties.FirstOrDefault(p => p.Name.Equals("Id", StringComparison.OrdinalIgnoreCase));
    var idVal = idProp?.GetValue(Model)?.ToString();
}

<div class="page-header d-flex justify-content-between align-items-center mb-4 p-4 bg-white rounded-4 shadow-sm border border-danger border-opacity-25">
    <div class="d-flex align-items-center">
        <div class="bg-danger bg-opacity-10 text-danger p-3 rounded-3 me-3">
            <i class="bi bi-exclamation-triangle-fill fs-4"></i>
        </div>
        <div>
            <h1 class="page-title h3 mb-1 fw-bolder text-danger">Delete @ViewBag.EntityName</h1>
            <p class="text-danger opacity-75 mb-0 small fw-bold">Are you absolutely sure you want to delete this record? This action cannot be undone.</p>
        </div>
    </div>
    <div>
        <a asp-action="List" asp-route-id="@ViewBag.EntityName" class="btn btn-light fw-bold shadow-sm border"><i class="bi bi-arrow-left me-1"></i> Cancel</a>
    </div>
</div>

<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="card border-danger border-opacity-25 shadow-sm rounded-4 mb-4">
            <div class="card-header bg-danger bg-opacity-10 border-danger border-opacity-25 p-4">
                <h5 class="fw-bolder mb-0 text-danger">Record Data to Delete</h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <tbody>
                        @foreach(var prop in properties) {
                            var val = prop.GetValue(Model);
                            <tr>
                                <th class="ps-4 py-3 bg-light text-secondary fw-bold text-uppercase" style="width: 30%; font-size: 0.8rem; letter-spacing: 0.5px;">@prop.Name</th>
                                <td class="pe-4 py-3 text-dark fw-medium">
                                    @if (val == null) {
                                        <span class="badge bg-light text-secondary border">null</span>
                                    } else if (val is bool b) {
                                        if (b) {
                                            <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-2 py-1"><i class="bi bi-check-circle-fill me-1"></i> True</span>
                                        } else {
                                            <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-2 py-1"><i class="bi bi-x-circle-fill me-1"></i> False</span>
                                        }
                                    } else {
                                        @val.ToString()
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="d-flex justify-content-end">
            <form asp-action="Delete" asp-route-id="@ViewBag.EntityName" asp-route-pk="@idVal" method="post">
                <a asp-action="List" asp-route-id="@ViewBag.EntityName" class="btn btn-lg btn-light fw-bold border text-muted px-4 me-2">Cancel</a>
                <button type="submit" class="btn btn-lg btn-danger fw-bold px-5 shadow-sm"><i class="bi bi-trash-fill me-2"></i> Confirm Deletion</button>
            </form>
        </div>
    </div>
</div>