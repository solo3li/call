@{
    ViewData["Title"] = "Database Schema Visualizer";
}

<style>
    /* Full-screen workspace layout */
    .workspace-container {
        display: flex;
        height: calc(100vh - 120px);
        margin: -20px -30px -30px -30px;
        background: #f8fafc;
        position: relative;
    }
    
    /* Left Sidebar: Table Explorer */
    .schema-sidebar {
        width: 300px;
        background: #fff;
        border-right: 1px solid #e2e8f0;
        display: flex;
        flex-direction: column;
        z-index: 10;
        box-shadow: 2px 0 10px rgba(0,0,0,0.02);
    }
    .schema-sidebar-header {
        padding: 20px;
        border-bottom: 1px solid #e2e8f0;
    }
    .schema-sidebar-body {
        flex: 1;
        overflow-y: auto;
        padding: 10px 0;
    }
    .entity-item {
        padding: 10px 20px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 12px;
        transition: all 0.2s;
        border-left: 3px solid transparent;
    }
    .entity-item:hover {
        background: #f1f5f9;
    }
    .entity-item.active {
        background: #eff6ff;
        border-left-color: #3b82f6;
    }
    .entity-color-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
    }
    
    /* Center Canvas */
    .schema-canvas-wrapper {
        flex: 1;
        position: relative;
        overflow: hidden;
    }
    #schemaNetwork {
        width: 100%;
        height: 100%;
        outline: none;
    }
    
    /* Canvas Controls Overlay */
    .canvas-controls {
        position: absolute;
        top: 20px;
        right: 20px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        z-index: 20;
    }
    .canvas-btn {
        width: 40px;
        height: 40px;
        border-radius: 8px;
        background: #fff;
        border: 1px solid #e2e8f0;
        color: #475569;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }
    .canvas-btn:hover {
        background: #f8fafc;
        color: #0f172a;
        transform: translateY(-1px);
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

    /* Right Sidebar: Deep Inspection Panel */
    .inspection-panel {
        width: 400px;
        background: #fff;
        border-left: 1px solid #e2e8f0;
        display: flex;
        flex-direction: column;
        z-index: 10;
        transform: translateX(100%);
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: absolute;
        right: 0;
        top: 0;
        bottom: 0;
        box-shadow: -4px 0 15px rgba(0,0,0,0.05);
    }
    .inspection-panel.open {
        transform: translateX(0);
    }
    .inspection-header {
        padding: 24px 20px;
        border-bottom: 1px solid #e2e8f0;
        background: #f8fafc;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .inspection-body {
        flex: 1;
        overflow-y: auto;
        padding: 0;
    }
    .property-row {
        display: flex;
        padding: 12px 20px;
        border-bottom: 1px solid #f1f5f9;
        align-items: center;
    }
    .property-row:hover {
        background: #f8fafc;
    }
    .prop-icon { width: 24px; color: #94a3b8; }
    .prop-name { flex: 1; font-weight: 600; color: #1e293b; font-size: 0.9rem; }
    .prop-type { font-size: 0.8rem; color: #64748b; font-family: monospace; background: #f1f5f9; padding: 2px 6px; border-radius: 4px; }
    
    .section-title {
        padding: 15px 20px 8px;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 800;
        color: #94a3b8;
        background: #fff;
    }
</style>

<div class="workspace-container">
    <!-- Left Explorer -->
    <div class="schema-sidebar">
        <div class="schema-sidebar-header">
            <h5 class="fw-bolder mb-3 text-dark">Data Explorer</h5>
            <div class="input-group input-group-sm">
                <span class="input-group-text bg-light border-end-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" class="form-control bg-light border-start-0 ps-0" id="searchTable" placeholder="Search tables...">
            </div>
        </div>
        <div class="schema-sidebar-body" id="tableList">
            <!-- Populated dynamically via JS -->
        </div>
    </div>

    <!-- Center Canvas -->
    <div class="schema-canvas-wrapper">
        <div id="schemaNetwork"></div>
        
        <div class="canvas-controls">
            <button class="canvas-btn" id="btnZoomIn" title="Zoom In"><i class="bi bi-zoom-in"></i></button>
            <button class="canvas-btn" id="btnZoomOut" title="Zoom Out"><i class="bi bi-zoom-out"></i></button>
            <button class="canvas-btn" id="btnFit" title="Fit to Screen"><i class="bi bi-arrows-fullscreen"></i></button>
            <button class="canvas-btn" id="btnPhysics" title="Toggle Physics (Gravity)"><i class="bi bi-magnet-fill text-primary"></i></button>
        </div>
    </div>

    <!-- Right Inspection Panel -->
    <div class="inspection-panel" id="inspectionPanel">
        <div class="inspection-header">
            <div>
                <span class="badge bg-primary bg-opacity-10 text-primary mb-1" id="panelGroup">Domain</span>
                <h4 class="fw-bolder mb-0 text-dark" id="panelTitle">Table Name</h4>
            </div>
            <button class="btn btn-sm btn-light text-secondary rounded-circle" id="btnClosePanel" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div class="inspection-body">
            <div class="section-title">Columns & Attributes</div>
            <div id="panelColumns">
                <!-- Columns injected here -->
            </div>
            
            <div class="section-title mt-2 border-top pt-3">Relationships (Navigation)</div>
            <div id="panelRelations">
                <!-- Relations injected here -->
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="text/javascript" src="https://unpkg.com/vis-network/standalone/umd/vis-network.min.js"></script>
    <script type="text/javascript">
        // Data parsed from controller
        const rawNodes = @Html.Raw(ViewBag.Nodes);
        const rawEdges = @Html.Raw(ViewBag.Edges);
        
        const nodes = new vis.DataSet(rawNodes);
        const edges = new vis.DataSet(rawEdges);

        const container = document.getElementById('schemaNetwork');
        const data = { nodes: nodes, edges: edges };
        
        const options = {
            layout: {
                improvedLayout: true,
                clusterThreshold: 150
            },
            interaction: {
                hover: true,
                tooltipDelay: 200,
                hideEdgesOnDrag: true,
                hideEdgesOnZoom: true
            },
            physics: {
                enabled: true,
                barnesHut: {
                    gravitationalConstant: -4000,
                    centralGravity: 0.1,
                    springLength: 200,
                    springConstant: 0.04,
                    damping: 0.09,
                    avoidOverlap: 0.5
                },
                stabilization: {
                    iterations: 200,
                    fit: true
                }
            }
        };
        
        const network = new vis.Network(container, data, options);

        // Sidebar population
        const tableList = document.getElementById('tableList');
        // Sort alphabetically
        const sortedNodes = [...rawNodes].sort((a,b) => a.label.localeCompare(b.label));
        
        sortedNodes.forEach(node => {
            const div = document.createElement('div');
            div.className = 'entity-item';
            div.id = 'list-item-' + node.id;
            div.innerHTML = `
                <div class="entity-color-dot" style="background-color: ${node.color.border}"></div>
                <div class="fw-medium text-dark flex-grow-1">${node.label}</div>
                <div class="text-muted small" style="font-size: 0.7rem;">${node.group.split(' ')[0]}</div>
            `;
            div.onclick = () => focusNode(node.id);
            tableList.appendChild(div);
        });

        // Search functionality
        document.getElementById('searchTable').addEventListener('input', function(e) {
            const term = e.target.value.toLowerCase();
            document.querySelectorAll('.entity-item').forEach(el => {
                const text = el.innerText.toLowerCase();
                el.style.display = text.includes(term) ? 'flex' : 'none';
            });
        });

        // Controls
        document.getElementById('btnZoomIn').onclick = () => {
            network.moveTo({ scale: network.getScale() * 1.2, animation: { duration: 300 } });
        };
        document.getElementById('btnZoomOut').onclick = () => {
            network.moveTo({ scale: network.getScale() * 0.8, animation: { duration: 300 } });
        };
        document.getElementById('btnFit').onclick = () => {
            network.fit({ animation: { duration: 500 } });
        };
        
        let physicsEnabled = true;
        document.getElementById('btnPhysics').onclick = (e) => {
            physicsEnabled = !physicsEnabled;
            network.setOptions({ physics: { enabled: physicsEnabled } });
            const icon = e.currentTarget.querySelector('i');
            if (physicsEnabled) {
                icon.className = 'bi bi-magnet-fill text-primary';
            } else {
                icon.className = 'bi bi-magnet text-muted';
            }
        };

        // Node Selection & Inspection
        network.on("click", function (params) {
            if (params.nodes.length > 0) {
                focusNode(params.nodes[0]);
            } else {
                closePanel();
                clearListSelection();
            }
        });

        document.getElementById('btnClosePanel').onclick = closePanel;

        function focusNode(nodeId) {
            // Highlight in network
            network.selectNodes([nodeId]);
            network.focus(nodeId, {
                scale: 1.2,
                animation: { duration: 400, easingFunction: "easeInOutQuad" }
            });
            
            // Highlight in list
            clearListSelection();
            const listItem = document.getElementById('list-item-' + nodeId);
            if(listItem) {
                listItem.classList.add('active');
                listItem.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }

            // Fetch and show details
            openPanel(nodeId);
        }

        function clearListSelection() {
            document.querySelectorAll('.entity-item').forEach(el => el.classList.remove('active'));
        }

        function closePanel() {
            document.getElementById('inspectionPanel').classList.remove('open');
        }

        function openPanel(nodeId) {
            const panel = document.getElementById('inspectionPanel');
            const nodeData = rawNodes.find(n => n.id === nodeId);
            
            document.getElementById('panelTitle').textContent = nodeData.label;
            document.getElementById('panelGroup').textContent = nodeData.group;
            document.getElementById('panelGroup').style.color = nodeData.color.border;
            document.getElementById('panelGroup').style.backgroundColor = nodeData.color.border + '1A';

            document.getElementById('panelColumns').innerHTML = '<div class="p-4 text-center text-muted"><div class="spinner-border spinner-border-sm mb-2"></div><br>Loading schema...</div>';
            document.getElementById('panelRelations').innerHTML = '';
            
            panel.classList.add('open');

            fetch(`/Admin/Manage/GetEntityProperties?id=${encodeURIComponent(nodeId)}`)
                .then(response => response.json())
                .then(data => {
                    const colsContainer = document.getElementById('panelColumns');
                    colsContainer.innerHTML = '';
                    
                    data.columns.forEach(col => {
                        let icon = '<i class="bi bi-list prop-icon"></i>';
                        if (col.isPrimaryKey) icon = '<i class="bi bi-key-fill text-warning prop-icon" title="Primary Key"></i>';
                        else if (col.isForeignKey) icon = '<i class="bi bi-link-45deg text-info prop-icon" title="Foreign Key"></i>';
                        
                        let reqBadge = col.isNullable ? '' : '<span class="badge bg-danger bg-opacity-10 text-danger ms-2" style="font-size:0.6rem;">REQ</span>';

                        colsContainer.innerHTML += `
                            <div class="property-row">
                                ${icon}
                                <div class="prop-name ms-2">${col.name} ${reqBadge}</div>
                                <div class="prop-type">${col.type}</div>
                            </div>
                        `;
                    });

                    const relsContainer = document.getElementById('panelRelations');
                    relsContainer.innerHTML = '';
                    
                    if (data.relations && data.relations.length > 0) {
                        data.relations.forEach(rel => {
                            let icon = rel.isCollection ? '<i class="bi bi-collection text-primary prop-icon"></i>' : '<i class="bi bi-arrow-right-short text-success prop-icon"></i>';
                            let targetLink = `<a href="javascript:void(0)" onclick="focusNode('${rel.target}')" class="text-decoration-none fw-bold">${rel.target}</a>`;
                            
                            relsContainer.innerHTML += `
                                <div class="property-row">
                                    ${icon}
                                    <div class="prop-name ms-2">${rel.name}</div>
                                    <div class="prop-type border-0 bg-transparent text-end">${targetLink}</div>
                                </div>
                            `;
                        });
                    } else {
                        relsContainer.innerHTML = '<div class="p-3 text-muted small italic">No navigation properties found.</div>';
                    }
                })
                .catch(err => {
                    document.getElementById('panelColumns').innerHTML = '<div class="p-3 text-danger">Failed to load properties.</div>';
                });
        }
    </script>
}