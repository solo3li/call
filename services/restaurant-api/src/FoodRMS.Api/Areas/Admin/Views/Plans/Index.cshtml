@model IEnumerable<FoodRMS.Api.Entities.Plan>

@{
    ViewData["Title"] = "Plans";
}

<div class="page-header">
    <h1 class="page-title">Subscription Plans</h1>
    <a asp-action="Create" class="btn btn-primary shadow-sm"><i class="bi bi-plus-lg me-1"></i> Create Plan</a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Limits</th>
                    <th>Price</th>
                    <th>Type</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
        @foreach (var item in Model) {
                <tr>
                    <td class="fw-medium text-dark">@item.Name</td>
                    <td>
                        <span class="badge bg-light text-dark border me-1"><i class="bi bi-shop me-1 text-muted"></i> @item.MaxBranches</span>
                        <span class="badge bg-light text-dark border"><i class="bi bi-people me-1 text-muted"></i> @item.MaxEmployees</span>
                    </td>
                    <td class="text-success fw-bold">@item.Price.ToString("C")</td>
                    <td>
                        @if(item.IsCustom) {
                            <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 px-2 py-1 rounded-pill">Custom</span>
                        } else {
                            <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 px-2 py-1 rounded-pill">Standard</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light border text-primary">
                            <i class="bi bi-pencil me-1"></i> Edit
                        </a>
                    </td>
                </tr>
        }
            </tbody>
        </table>
    </div>
</div>