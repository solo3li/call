@model IEnumerable<FoodRMS.Api.Entities.SupportTicket>

@{
    ViewData["Title"] = "Support Tickets";
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title m-0">Support Tickets & Complaints</h1>
    <div class="d-flex gap-2">
        <a asp-action="Index" asp-route-filter="" class="btn @(ViewBag.CurrentFilter != "complaints" ? "btn-primary" : "btn-light border text-dark") shadow-sm">
            <i class="bi bi-inbox me-1"></i> All Tickets
        </a>
        <a asp-action="Index" asp-route-filter="complaints" class="btn @(ViewBag.CurrentFilter == "complaints" ? "btn-danger text-white" : "btn-light border text-danger") shadow-sm">
            <i class="bi bi-exclamation-octagon me-1"></i> Customer Complaints (Bot)
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th>Status</th>
                    <th>Type</th>
                    <th>Ticket Title</th>
                    <th>Customer</th>
                    <th>Tenant</th>
                    <th>Last Updated</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ticket in Model)
                {
                    <tr style="cursor: pointer;" onclick="window.location.href='/Admin/Support/Chat/@ticket.Id'">
                        <td>
                            @if(ticket.Status == "Open") {
                                <span class="badge bg-warning text-dark border border-warning px-2 py-1 rounded-pill">Open</span>
                            } else {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-2 py-1 rounded-pill">Closed</span>
                            }
                        </td>
                        <td>
                            @if(ticket.IsComplaint) {
                                <span class="badge bg-danger text-white px-2 py-1 rounded-pill"><i class="bi bi-exclamation-triangle-fill me-1"></i> Complaint</span>
                            } else {
                                <span class="badge bg-info text-white px-2 py-1 rounded-pill"><i class="bi bi-question-circle-fill me-1"></i> Inquiry</span>
                            }
                        </td>
                        <td class="fw-medium text-dark">@ticket.Title</td>
                        <td class="text-muted">@(string.IsNullOrEmpty(ticket.CustomerName) ? "N/A" : ticket.CustomerName)</td>
                        <td class="text-muted">@(ticket.Tenant?.Name ?? "General Inquiry")</td>
                        <td class="text-muted small">@ticket.UpdatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                        <td class="text-end">
                            <a asp-action="Chat" asp-route-id="@ticket.Id" class="btn btn-sm btn-light border text-primary">
                                <i class="bi bi-chat-dots me-1"></i> Open Chat
                            </a>
                        </td>
                    </tr>
                }
                @if(!Model.Any()) {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-5">
                            <i class="bi bi-inbox fs-1 d-block mb-2 text-secondary opacity-50"></i>
                            No active support tickets or complaints.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>