@model FoodRMS.Api.Entities.SupportTicket

@{
    ViewData["Title"] = "Ticket: " + Model.Title;
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <a asp-action="Index" class="btn btn-sm btn-light border text-dark mb-2"><i class="bi bi-arrow-left"></i> Back to Tickets</a>
        <h1 class="page-title m-0">
            @Model.Title 
            @if(Model.IsComplaint) {
                <span class="badge bg-danger text-white fs-6 ms-2 align-middle"><i class="bi bi-exclamation-triangle-fill me-1"></i> Bot Complaint Escalation</span>
            }
        </h1>
        <div class="text-muted small mt-1">
            Customer: @(string.IsNullOrEmpty(Model.CustomerName) ? "N/A" : Model.CustomerName) | 
            Tenant: @(Model.Tenant?.Name ?? "General") | 
            Status: @Model.Status
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm d-flex flex-column" style="height: 70vh;">
    <!-- Chat History -->
    <div class="card-body overflow-auto flex-grow-1 p-4" id="chatHistory" style="background-color: #f8fafc;">
        @foreach (var msg in Model.Messages.OrderBy(m => m.CreatedAt))
        {
            var isAdmin = msg.Sender == "Admin";
            <div class="d-flex mb-4 @(isAdmin ? "justify-content-end" : "justify-content-start")">
                <div class="d-flex flex-column align-items-@(isAdmin ? "end" : "start")" style="max-width: 70%;">
                    <div class="small text-muted mb-1 px-1">@msg.Sender • @msg.CreatedAt.ToString("HH:mm")</div>
                    <div class="p-3 rounded-4 shadow-sm @(isAdmin ? "bg-primary text-white" : "bg-white border text-dark")">
                        
                        @if (msg.MessageType == "Text")
                        {
                            <span style="white-space: pre-wrap;">@msg.Text</span>
                        }
                        else if (msg.MessageType == "Image")
                        {
                            <img src="@msg.AttachmentUrl" class="img-fluid rounded mb-2" style="max-height: 200px;" alt="@msg.AttachmentName" />
                            @if(!string.IsNullOrEmpty(msg.Text)) { <div class="mt-2">@msg.Text</div> }
                        }
                        else if (msg.MessageType == "Audio")
                        {
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-mic-fill fs-4"></i>
                                <audio controls src="@msg.AttachmentUrl" class="rounded" style="height: 35px;"></audio>
                            </div>
                            @if(!string.IsNullOrEmpty(msg.Text)) { <div class="mt-2">@msg.Text</div> }
                        }
                        else if (msg.MessageType == "Video")
                        {
                            <video controls src="@msg.AttachmentUrl" class="img-fluid rounded mb-2" style="max-height: 250px;"></video>
                            @if(!string.IsNullOrEmpty(msg.Text)) { <div class="mt-2">@msg.Text</div> }
                        }
                        @if (msg.MessageType == "File")
                        {
                            <div class="d-flex align-items-center p-2 rounded bg-opacity-10 @(isAdmin ? "bg-white text-white" : "bg-dark text-dark") border border-opacity-25">
                                <i class="bi bi-file-earmark-arrow-down fs-3 me-2"></i>
                                <div>
                                    <a href="@msg.AttachmentUrl" target="_blank" class="@(isAdmin ? "text-white fw-bold" : "text-dark fw-bold") text-decoration-none">@msg.AttachmentName</a>
                                </div>
                            </div>
                            @if(!string.IsNullOrEmpty(msg.Text)) { <div class="mt-2">@msg.Text</div> }
                        }
                        </div>
                        <button class="btn btn-sm btn-link text-muted p-0 mt-1" style="font-size: 0.75rem; text-decoration: none;" onclick="setReply('@msg.Id', `@Html.Raw(msg.Text.Replace("`", "\\`"))`, '@msg.Sender')"><i class="bi bi-reply-fill"></i> Reply</button>
                        </div>
                        </div>
                        }
                        </div>

                        <!-- Reply Preview Area (Hidden by default) -->
                        <div id="replyPreviewArea" class="bg-light border-top p-2 px-3 d-none align-items-center justify-content-between">
                        <div class="d-flex flex-column" style="border-left: 3px solid var(--accent-color); padding-left: 10px;">
                        <small class="fw-bold text-primary" id="replyToUser"></small>
                        <small class="text-muted text-truncate" id="replyToText" style="max-width: 500px;"></small>
                        </div>
                        <button type="button" class="btn-close" aria-label="Close" onclick="clearReply()"></button>
                        </div>

                        <!-- Media Preview Area (Hidden by default) -->
    <div id="mediaPreviewArea" class="bg-light border-top p-3 d-none align-items-center position-relative">
        <button type="button" class="btn-close position-absolute top-0 end-0 m-2" aria-label="Close" onclick="clearPreview()"></button>
        <div id="previewContent" class="d-flex align-items-center gap-3"></div>
    </div>

    <!-- Audio Recording Area (Hidden by default) -->
    <div id="audioRecordArea" class="bg-light border-top p-3 d-none align-items-center justify-content-between position-relative">
        <div class="d-flex align-items-center gap-3 w-100">
            <button class="btn btn-danger rounded-circle p-2 shadow-sm" onclick="stopRecording(false)"><i class="bi bi-trash"></i></button>
            <div class="flex-grow-1 bg-dark rounded overflow-hidden" style="height: 40px; position: relative;">
                <canvas id="audioVisualizer" style="width: 100%; height: 100%;"></canvas>
            </div>
            <div class="text-danger fw-bold" id="recordTimer">00:00</div>
            <button class="btn btn-success rounded-circle p-2 shadow-sm" onclick="stopRecording(true)"><i class="bi bi-check-lg"></i></button>
        </div>
    </div>

    <!-- Chat Input Area -->
    <div class="card-footer bg-white border-top p-3">
        <form id="chatForm" onsubmit="sendMessage(event)">
            <input type="hidden" id="ticketId" value="@Model.Id" />
            <input type="hidden" id="messageType" value="Text" />
            <input type="file" id="fileInput" class="d-none" onchange="handleFileSelect(event)" />
            
            <div class="input-group">
                <button type="button" class="btn btn-light border text-muted" onclick="document.getElementById('fileInput').click()" title="Attach File/Image/Video">
                    <i class="bi bi-paperclip fs-5"></i>
                </button>
                <button type="button" class="btn btn-light border text-danger" id="micBtn" onclick="startRecording()" title="Record Audio">
                    <i class="bi bi-mic-fill fs-5"></i>
                </button>
                
                <input type="text" id="messageText" class="form-control" placeholder="Type a professional response..." autocomplete="off">
                
                <button type="submit" class="btn btn-primary px-4 fw-medium">Send <i class="bi bi-send ms-1"></i></button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        const chatHistory = document.getElementById('chatHistory');
        chatHistory.scrollTop = chatHistory.scrollHeight;

        let selectedFile = null;
        let selectedAudioBlob = null;
        
        let mediaRecorder;
        let audioChunks = [];
        let recordInterval;
        let audioContext;
        let analyser;
        let canvas = document.getElementById('audioVisualizer');
        let canvasCtx = canvas.getContext('2d');
        let animationId;

        // --- File Preview Logic ---
        function handleFileSelect(event) {
            const file = event.target.files[0];
            if (!file) return;

            selectedFile = file;
            let type = "File";
            let previewHtml = '';

            if (file.type.startsWith('image/')) {
                type = "Image";
                const url = URL.createObjectURL(file);
                previewHtml = `<img src="${url}" class="rounded shadow-sm" style="height: 60px; width: auto;" />
                               <div><div class="fw-bold small mb-0">${file.name}</div><div class="text-muted" style="font-size: 0.7rem;">Image Attached</div></div>`;
            } else if (file.type.startsWith('video/')) {
                type = "Video";
                const url = URL.createObjectURL(file);
                previewHtml = `<video src="${url}" class="rounded shadow-sm bg-dark" style="height: 60px; width: auto;"></video>
                               <div><div class="fw-bold small mb-0">${file.name}</div><div class="text-muted" style="font-size: 0.7rem;">Video Attached</div></div>`;
            } else {
                previewHtml = `<div class="bg-secondary bg-opacity-10 p-2 rounded text-dark"><i class="bi bi-file-earmark-text fs-4 me-2"></i></div>
                               <div><div class="fw-bold small mb-0">${file.name}</div><div class="text-muted" style="font-size: 0.7rem;">File Attached</div></div>`;
            }

            document.getElementById('messageType').value = type;
            document.getElementById('previewContent').innerHTML = previewHtml;
            document.getElementById('mediaPreviewArea').classList.remove('d-none');
            document.getElementById('mediaPreviewArea').classList.add('d-flex');
        }

        function clearPreview() {
            selectedFile = null;
            selectedAudioBlob = null;
            document.getElementById('messageType').value = "Text";
            document.getElementById('fileInput').value = "";
            document.getElementById('mediaPreviewArea').classList.add('d-none');
            document.getElementById('mediaPreviewArea').classList.remove('d-flex');
            document.getElementById('audioRecordArea').classList.add('d-none');
            document.getElementById('audioRecordArea').classList.remove('d-flex');
        }

        // --- Audio Recording & Visualizer ---
        async function startRecording() {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                mediaRecorder = new MediaRecorder(stream);
                audioChunks = [];
                
                // Audio Visualizer Setup
                audioContext = new (window.AudioContext || window.webkitAudioContext)();
                const source = audioContext.createMediaStreamSource(stream);
                analyser = audioContext.createAnalyser();
                analyser.fftSize = 256;
                source.connect(analyser);
                
                drawVisualizer();

                mediaRecorder.ondataavailable = e => {
                    if (e.data.size > 0) audioChunks.push(e.data);
                };

                mediaRecorder.start();
                
                // UI changes
                clearPreview();
                document.getElementById('audioRecordArea').classList.remove('d-none');
                document.getElementById('audioRecordArea').classList.add('d-flex');
                document.getElementById('messageType').value = "Audio";
                
                let seconds = 0;
                document.getElementById('recordTimer').innerText = "00:00";
                recordInterval = setInterval(() => {
                    seconds++;
                    const m = String(Math.floor(seconds / 60)).padStart(2, '0');
                    const s = String(seconds % 60).padStart(2, '0');
                    document.getElementById('recordTimer').innerText = `${m}:${s}`;
                }, 1000);

            } catch (err) {
                console.error("Microphone access denied", err);
                alert("Microphone access is required to record audio.");
            }
        }

        function drawVisualizer() {
            if(!analyser) return;
            animationId = requestAnimationFrame(drawVisualizer);
            const bufferLength = analyser.frequencyBinCount;
            const dataArray = new Uint8Array(bufferLength);
            analyser.getByteFrequencyData(dataArray);

            canvas.width = canvas.parentElement.clientWidth;
            canvas.height = canvas.parentElement.clientHeight;
            
            canvasCtx.fillStyle = '#212529'; // dark bg
            canvasCtx.fillRect(0, 0, canvas.width, canvas.height);

            const barWidth = (canvas.width / bufferLength) * 2.5;
            let barHeight;
            let x = 0;

            for(let i = 0; i < bufferLength; i++) {
                barHeight = dataArray[i] / 2;
                canvasCtx.fillStyle = '#ef4444'; // bootstrap danger red
                canvasCtx.fillRect(x, canvas.height - barHeight, barWidth, barHeight);
                x += barWidth + 1;
            }
        }

        function stopRecording(save) {
            if(mediaRecorder && mediaRecorder.state !== 'inactive') {
                mediaRecorder.stop();
                mediaRecorder.stream.getTracks().forEach(t => t.stop());
            }
            clearInterval(recordInterval);
            cancelAnimationFrame(animationId);
            if(audioContext) audioContext.close();

            document.getElementById('audioRecordArea').classList.add('d-none');
            document.getElementById('audioRecordArea').classList.remove('d-flex');

            if (save) {
                mediaRecorder.onstop = () => {
                    selectedAudioBlob = new Blob(audioChunks, { type: 'audio/webm' });
                    
                    // Show audio in generic preview area
                    const url = URL.createObjectURL(selectedAudioBlob);
                    document.getElementById('messageType').value = "Audio";
                    document.getElementById('previewContent').innerHTML = `
                        <div class="bg-danger bg-opacity-10 text-danger p-2 rounded"><i class="bi bi-mic-fill fs-4 me-2"></i></div>
                        <div class="flex-grow-1"><audio controls src="${url}" class="rounded" style="height: 40px;"></audio></div>
                    `;
                    document.getElementById('mediaPreviewArea').classList.remove('d-none');
                    document.getElementById('mediaPreviewArea').classList.add('d-flex');
                };
            } else {
                clearPreview();
            }
        }

        // --- Reply Logic ---
        let replyToMessageId = null;

        function setReply(id, text, sender) {
            replyToMessageId = id;
            document.getElementById('replyToUser').innerText = `Replying to ${sender}`;
            document.getElementById('replyToText').innerText = text;
            document.getElementById('replyPreviewArea').classList.remove('d-none');
            document.getElementById('replyPreviewArea').classList.add('d-flex');
        }

        function clearReply() {
            replyToMessageId = null;
            document.getElementById('replyPreviewArea').classList.add('d-none');
            document.getElementById('replyPreviewArea').classList.remove('d-flex');
        }

        // --- SignalR Connection & Real-Time DOM ---
        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
        }

        function appendMessageToDOM(msg) {
            if (document.querySelector(`button[onclick*="${msg.id}"]`)) return;

            const isAdmin = msg.sender === "Admin";
            const timeStr = new Date(msg.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            
            const outerDiv = document.createElement('div');
            outerDiv.className = `d-flex mb-4 ${isAdmin ? "justify-content-end" : "justify-content-start"}`;
            
            let contentHtml = '';
            if (msg.messageType === "Text") {
                contentHtml = `<span style="white-space: pre-wrap;">${escapeHtml(msg.text)}</span>`;
            } else if (msg.messageType === "Image") {
                contentHtml = `<img src="${msg.attachmentUrl}" class="img-fluid rounded mb-2" style="max-height: 200px;" alt="${escapeHtml(msg.attachmentName || '')}" />`;
                if (msg.text) contentHtml += `<div class="mt-2">${escapeHtml(msg.text)}</div>`;
            } else if (msg.messageType === "Audio") {
                contentHtml = `<div class="d-flex align-items-center gap-2">
                                <i class="bi bi-mic-fill fs-4"></i>
                                <audio controls src="${msg.attachmentUrl}" class="rounded" style="height: 35px;"></audio>
                               </div>`;
                if (msg.text) contentHtml += `<div class="mt-2">${escapeHtml(msg.text)}</div>`;
            } else if (msg.messageType === "Video") {
                contentHtml = `<video controls src="${msg.attachmentUrl}" class="img-fluid rounded mb-2" style="max-height: 250px;"></video>`;
                if (msg.text) contentHtml += `<div class="mt-2">${escapeHtml(msg.text)}</div>`;
            } else if (msg.messageType === "File") {
                contentHtml = `<div class="d-flex align-items-center p-2 rounded bg-opacity-10 ${isAdmin ? "bg-white text-white" : "bg-dark text-dark"} border border-opacity-25">
                                <i class="bi bi-file-earmark-arrow-down fs-3 me-2"></i>
                                <div>
                                    <a href="${msg.attachmentUrl}" target="_blank" class="${isAdmin ? "text-white fw-bold" : "text-dark fw-bold"} text-decoration-none">${escapeHtml(msg.attachmentName || 'Attachment')}</a>
                                </div>
                               </div>`;
                if (msg.text) contentHtml += `<div class="mt-2">${escapeHtml(msg.text)}</div>`;
            }

            const safeTextForReply = msg.text ? msg.text.replace(/`/g, '\\`').replace(/'/g, "\\'") : '';
            
            outerDiv.innerHTML = `
                <div class="d-flex flex-column align-items-${isAdmin ? "end" : "start"}" style="max-width: 70%;">
                    <div class="small text-muted mb-1 px-1">${msg.sender} • ${timeStr}</div>
                    <div class="p-3 rounded-4 shadow-sm ${isAdmin ? "bg-primary text-white" : "bg-white border text-dark"}">
                        ${contentHtml}
                    </div>
                    <button class="btn btn-sm btn-link text-muted p-0 mt-1" style="font-size: 0.75rem; text-decoration: none;" onclick="setReply('${msg.id}', \`${safeTextForReply}\`, '${msg.sender}')"><i class="bi bi-reply-fill"></i> Reply</button>
                </div>
            `;
            
            chatHistory.appendChild(outerDiv);
            chatHistory.scrollTop = chatHistory.scrollHeight;
        }

        let connection = null;
        if (typeof signalR !== 'undefined') {
            connection = new signalR.HubConnectionBuilder()
                .withUrl("/supportHub")
                .withAutomaticReconnect()
                .build();
            connection.start().then(() => {
                const tId = document.getElementById('ticketId').value;
                connection.invoke("JoinTicketGroup", tId).catch(err => console.error(err));
            }).catch(err => console.error("SignalR connection error:", err));

            connection.on("ReceiveMessage", (msg) => {
                appendMessageToDOM(msg);
            });
        }

        // --- Sending Logic ---
        function sendMessage(e) {
            e.preventDefault();
            
            const ticketId = document.getElementById('ticketId').value;
            const text = document.getElementById('messageText').value;
            const msgType = document.getElementById('messageType').value;
            
            if (!text.trim() && !selectedFile && !selectedAudioBlob) return;

            const formData = new FormData();
            formData.append('ticketId', ticketId);
            formData.append('text', text);
            formData.append('messageType', msgType);

            if (replyToMessageId) {
                formData.append('replyToMessageId', replyToMessageId);
            }

            if (selectedFile) {
                formData.append('attachment', selectedFile);
            } else if (selectedAudioBlob) {
                formData.append('attachment', selectedAudioBlob, 'voice_message.webm');
            }

            const btn = document.querySelector('button[type="submit"]');
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Sending...';
            btn.disabled = true;

            fetch('/Admin/Support/SendMessage', {
                method: 'POST',
                body: formData
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    document.getElementById('messageText').value = '';
                    clearPreview();
                    clearReply();
                    btn.innerHTML = 'Send <i class="bi bi-send ms-1"></i>';
                    btn.disabled = false;
                    
                    // Note: Backend now handles the SignalR "ReceiveMessage" broadcast to the group.
                    // If for some reason SignalR is not connected, we append it manually as a fallback.
                    if (!connection || connection.state !== signalR.HubConnectionState.Connected) {
                        appendMessageToDOM(data.message);
                    }
                }
            })
            .catch(err => {
                console.error(err);
                btn.innerHTML = 'Send <i class="bi bi-send ms-1"></i>';
                btn.disabled = false;
            });
        }
    </script>
}