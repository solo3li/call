@model DashboardViewModel
@{
    ViewData["Title"] = "Analytics Dashboard";
}

<style>
    .stat-card {
        background: #fff;
        border: none;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        position: relative;
        overflow: hidden;
    }
    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
    }
    .stat-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: var(--accent-color);
    }
    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }
    .stat-label {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 1px;
        color: #64748b;
        margin-bottom: 5px;
    }
    .stat-value {
        font-weight: 800;
        font-size: 1.75rem;
        color: #0f172a;
        margin: 0;
    }
    .chart-card {
        background: #fff;
        border: none;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        padding: 24px;
    }
</style>

<div class="page-header d-flex justify-content-between align-items-center mb-4 p-4 bg-white rounded-4 shadow-sm">
    <div>
        <h1 class="page-title h3 mb-1 fw-bolder text-dark">Enterprise Overview</h1>
        <p class="text-muted mb-0 small">Live analytics and core metrics for your SaaS platform.</p>
    </div>
    <div class="text-end">
        <span class="text-muted small fw-bold">Date:</span>
        <div class="fw-bolder text-primary">@DateTime.Now.ToString("MMMM dd, yyyy")</div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Stat Cards -->
    <div class="col-md-4 col-xl-2">
        <div class="stat-card p-4" style="--accent-color: #3b82f6;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-label">Total Tenants</div>
                    <h3 class="stat-value">@Model.TotalTenants</h3>
                </div>
                <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                    <i class="bi bi-buildings-fill"></i>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-4 col-xl-2">
        <div class="stat-card p-4" style="--accent-color: #10b981;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-label">Active Subs</div>
                    <h3 class="stat-value text-success">@Model.ActiveTenants</h3>
                </div>
                <div class="stat-icon bg-success bg-opacity-10 text-success">
                    <i class="bi bi-activity"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-xl-2">
        <div class="stat-card p-4" style="--accent-color: #ef4444;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-label">Open Tickets</div>
                    <h3 class="stat-value text-danger">@Model.OpenSupportTickets</h3>
                </div>
                <div class="stat-icon bg-danger bg-opacity-10 text-danger">
                    <i class="bi bi-ticket-detailed-fill"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-xl-2">
        <div class="stat-card p-4" style="--accent-color: #8b5cf6;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-label">Plans</div>
                    <h3 class="stat-value text-indigo" style="color:#8b5cf6;">@Model.TotalPlans</h3>
                </div>
                <div class="stat-icon bg-indigo bg-opacity-10 text-indigo" style="color: #8b5cf6; background: rgba(139,92,246,0.1);">
                    <i class="bi bi-tags-fill"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-xl-2">
        <div class="stat-card p-4" style="--accent-color: #f59e0b;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-label">Branches</div>
                    <h3 class="stat-value text-warning">@Model.TotalBranches</h3>
                </div>
                <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                    <i class="bi bi-shop"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-xl-2">
        <div class="stat-card p-4" style="--accent-color: #06b6d4;">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="stat-label">Est. Revenue</div>
                    <h3 class="stat-value text-info">$@Model.TotalEstimatedRevenue.ToString("N0")</h3>
                </div>
                <div class="stat-icon bg-info bg-opacity-10 text-info">
                    <i class="bi bi-currency-dollar"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="chart-card h-100">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bolder text-dark mb-0">Platform Growth</h5>
                <button class="btn btn-sm btn-light border fw-bold"><i class="bi bi-download me-1"></i> Export</button>
            </div>
            <div style="height: 300px;">
                <canvas id="growthChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="chart-card h-100">
            <h5 class="fw-bolder text-dark mb-4">Revenue by Plan</h5>
            <div style="height: 300px; display: flex; justify-content: center;">
                <canvas id="planChart"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-header bg-white border-bottom p-4">
        <h5 class="fw-bolder mb-0">Recent Onboarding Activity</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-secondary">
                    <tr>
                        <th class="ps-4 fw-bold text-uppercase" style="font-size: 0.8rem;">Tenant Name</th>
                        <th class="fw-bold text-uppercase" style="font-size: 0.8rem;">Plan Tier</th>
                        <th class="fw-bold text-uppercase" style="font-size: 0.8rem;">Join Date</th>
                        <th class="pe-4 fw-bold text-uppercase text-end" style="font-size: 0.8rem;">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var tenant in Model.RecentTenants)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-dark">
                                <div class="d-flex align-items-center">
                                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 36px; height: 36px;">
                                        @tenant.Name.Substring(0, 1).ToUpper()
                                    </div>
                                    @tenant.Name
                                </div>
                            </td>
                            <td><span class="badge bg-secondary bg-opacity-10 text-secondary border px-2 py-1">@tenant.Plan</span></td>
                            <td class="text-muted fw-medium">@tenant.Date</td>
                            <td class="pe-4 text-end">
                                @if(tenant.Status == "Active") {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-2 py-1"><i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i> Active</span>
                                } else {
                                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 px-2 py-1"><i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i> Pending</span>
                                }
                            </td>
                        </tr>
                    }
                    @if(!Model.RecentTenants.Any())
                    {
                        <tr><td colspan="4" class="text-center py-5 text-muted">No recent activity found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        Chart.defaults.font.family = "system-ui, -apple-system, sans-serif";
        Chart.defaults.color = "#64748b";
        
        // Growth Chart
        const growthCtx = document.getElementById('growthChart').getContext('2d');
        
        // Create Gradient
        let gradient = growthCtx.createLinearGradient(0, 0, 0, 300);
        gradient.addColorStop(0, 'rgba(59, 130, 246, 0.4)');
        gradient.addColorStop(1, 'rgba(59, 130, 246, 0.0)');

        new Chart(growthCtx, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.TenantGrowth.Select(s => s.Label))),
                datasets: [{
                    label: 'New Tenants',
                    data: @Html.Raw(Json.Serialize(Model.TenantGrowth.Select(s => s.Value))),
                    borderColor: '#3b82f6',
                    backgroundColor: gradient,
                    borderWidth: 3,
                    pointBackgroundColor: '#fff',
                    pointBorderColor: '#3b82f6',
                    pointBorderWidth: 2,
                    pointRadius: 4,
                    pointHoverRadius: 6,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: '#0f172a',
                        padding: 12,
                        titleFont: { size: 13 },
                        bodyFont: { size: 14, weight: 'bold' },
                        displayColors: false,
                        cornerRadius: 8
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: '#f1f5f9', drawBorder: false },
                        border: { display: false }
                    },
                    x: {
                        grid: { display: false },
                        border: { display: false }
                    }
                }
            }
        });

        // Plan Distribution
        const planCtx = document.getElementById('planChart').getContext('2d');
        new Chart(planCtx, {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.PlanDistribution.Select(p => p.PlanName))),
                datasets: [{
                    data: @Html.Raw(Json.Serialize(Model.PlanDistribution.Select(p => p.Count))),
                    backgroundColor: ['#3b82f6', '#10b981', '#8b5cf6', '#f59e0b', '#ef4444'],
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '75%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { padding: 20, usePointStyle: true, pointStyle: 'circle' }
                    }
                }
            }
        });
    </script>
}