@model IEnumerable<FoodRMS.Api.Entities.Tenant>

@{
    ViewData["Title"] = "Tenants";
}

<div class="page-header">
    <h1 class="page-title">Tenants</h1>
    <a asp-action="Create" class="btn btn-primary shadow-sm"><i class="bi bi-plus-lg me-1"></i> Provision Tenant</a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Subdomain</th>
                    <th>Plan</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
        @foreach (var item in Model) {
                <tr>
                    <td class="fw-medium text-dark">@item.Name</td>
                    <td><span class="badge bg-light text-dark border text-lowercase px-2 py-1"><i class="bi bi-globe me-1 text-muted"></i>@item.Subdomain</span></td>
                    <td>@(item.Plan?.Name ?? "No Plan")</td>
                    <td>
                        @if(item.IsActive) {
                            <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-2 py-1 rounded-pill"><i class="bi bi-check-circle-fill me-1"></i> Active</span>
                        } else {
                            <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 px-2 py-1 rounded-pill">Inactive</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-light border text-primary">
                            <i class="bi bi-pencil me-1"></i> Edit
                        </a>
                    </td>
                </tr>
        }
            </tbody>
        </table>
    </div>
</div>